# Supabase — obter em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Apenas para operações server-side privilegiadas (nunca expor no browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Segredo do Vercel Cron — protege /api/cron/daily (ver vercel.json)
CRON_SECRET=defina-um-valor-aleatorio-longo

# Integração AT — comunicação de contratos e emissão de recibos (SOAP/WSDL)
# Ver docs/at-arrendamento/CHECKLIST.md. Sem estas variáveis a app funciona em
# modo mock (AT_ENV=mock, omisso): nenhuma chamada real é feita à AT.
AT_ENV=mock
AT_TEST_ENDPOINT=https://servicos.portaldasfinancas.gov.pt:709/ws/arrendamento
AT_PROD_ENDPOINT=https://servicos.portaldasfinancas.gov.pt:409/ws/arrendamento
AT_ENDPOINT_OVERRIDE=
# Chave pública do Sistema de Autenticação da AT (formato PEM), obtida por
# email junto de asi-cd@at.gov.pt — nunca commitar o valor real.
AT_AUTH_PUBLIC_KEY_PEM=
# Certificado cliente assinado pela AT, em PFX codificado em Base64.
AT_CLIENT_CERT_PFX_BASE64=
AT_CLIENT_CERT_PFX_PASSWORD=
AT_SOAP_TIMEOUT_MS=30000
AT_LOG_LEVEL=info
